{
  "name": "vue-examples",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm run test",
    "check:supply-chain": "node scripts/check-lockfile.mjs && node scripts/check-install-scripts.mjs",
    "sbom": "npm sbom --sbom-format=cyclonedx --cache ./.npm-cache",
    "audit": "npm audit --audit-level=moderate --cache ./.npm-cache",
    "audit:signatures": "node scripts/audit-signatures.mjs"
  },
  "dependencies": {
    "lodash-es": "4.18.1",
    "marked": "18.0.3",
    "vue": "3.5.34",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/lodash-es": "4.17.12",
    "@types/marked": "5.0.2",
    "@types/node": "25.6.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "4.1.6",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "eslint": "10.3.0",
    "eslint-plugin-vue": "10.9.1",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.11",
    "vitest": "4.1.6",
    "vue-tsc": "3.2.8"
  }
}